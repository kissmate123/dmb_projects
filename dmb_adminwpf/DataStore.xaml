<Window x:Class="dmb_adminwpf.DataStore"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dmb_adminwpf"
        mc:Ignorable="d"
        Title="DataStore" Height="450" Width="250">
    <Grid>
        <WrapPanel Orientation="Vertical">
            <Label Content="Username"/>
            <TextBox x:Name="tbxUN" Width="200" Margin="10"/>
            <Label Content="Email"/>
            <TextBox x:Name="tbxEmail" Width="200" Margin="10"/>
            <Label Content="Password"/>
            <TextBox x:Name="tbxPW" Width="200" Margin="10"/>
            <Button x:Name="btnOk" Content="OK" Margin="10" Click="btnOk_Click" Background="#107C10"/>
        </WrapPanel>
    </Grid>
</Window>
