<Window x:Class="dmb_adminwpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ADMIN PANEL - Csak Szerkesztés"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="White">
            <MenuItem Header="_Fájl">
                <MenuItem x:Name="miExit" Header="Kilépés" Click="btnExit_Click" InputGestureText="ESC"/>
            </MenuItem>
        </Menu>

        <Grid Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="12" Padding="10" Margin="0,0,20,0">
                <DataGrid x:Name="dtgAdatok" ColumnWidth="*" AutoGenerateColumns="True"/>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="txtStatusz" Margin="50 30" VerticalAlignment="Center" TextWrapping="Wrap" />

                        <Button x:Name="btnModify"
                                Content="Módosítás"
                                Background="#0078D4"
                                Click="btnModify_Click" 
                                Margin="50 30"
                                Foreground="White"/>

                        <Button x:Name="btnDelete"
                                Content="Törlés"
                                Background="#E81123"
                                Click="btnDelete_Click" 
                                Margin="50 30"
                                Foreground="White"/>
                    </StackPanel>

                    <Button Grid.Row="1"
                            x:Name="btnExit"
                            Content="Kilépés"
                            Background="#6C757D"
                            Click="btnExit_Click"
                            IsCancel="True"
                            Margin="0,20,0,0"
                            Foreground="White"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>