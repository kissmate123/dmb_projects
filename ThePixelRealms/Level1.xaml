        <Grid x:Name="PauseOverlay"
              Background="#AA000000"
              Visibility="Collapsed">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="400">

                <TextBlock Text="PAUSE"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Button Content="Folytatás"
                        Height="50"
                        Margin="0,0,0,15"
                        Click="Resume_Click"/>

                <Button Content="Kilépés a főmenübe"
                        Height="50"
                        Margin="0,0,0,15"
                        Click="ExitToMenu_Click"/>

                <Button Content="Kilépés a játékból"
                        Height="50"
                        Click="ExitGame_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="Dead"
              Background="#AA000000"
              Visibility="Collapsed">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="400">

                <TextBlock Text="MEGHALTÁL"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="Red"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Button Content="Újraéledés"
                        Height="50"
                        Margin="0,0,0,15"
                        Click="Respawn_Click"/>

                <Button Content="Kilépés a főmenübe"
                        Height="50"
                        Margin="0,0,0,15"
                        Click="ExitToMenu_Click"/>

                <Button Content="Kilépés a játékból"
                        Height="50"
                        Click="ExitGame_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="FinishOverlay"
              Background="#AA000000"
              Visibility="Collapsed">

            <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="600">

                <TextBlock Text="SZINT SIKERESEN TELJESÍTVE"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="LimeGreen"
                   TextAlignment="Center"
                   Margin="0,0,0,30"/>

                <Button Content="Kilépés a főmenübe"
                        Height="50"
                        Width="400"
                        Click="ExitToMenu_Click"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="DebugText"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="50"
                   FontSize="16"
                   Foreground="Black"/>
