<Window x:Class="ThePixelRealms.LevelSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ThePixelRealms"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#1E1E1E" Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PÁLYAVÁLASZTÁS"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,20"
                   Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <UniformGrid Rows="2" Columns="3" Margin="40">

                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="200"
                                Height="100"
                                Click="Level1_Click"
                                Background="#444">
                            <TextBlock Text="LEVEL 1"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="Kezdő pálya"
                                   Foreground="LightGray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="200"
                                Height="100"
                                IsEnabled="False"
                                Background="#333"/>
                        <TextBlock Text="Level 2"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="200"
                                Height="100"
                                IsEnabled="False"
                                Background="#333"/>
                        <TextBlock Text="Level 3"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="200"
                                Height="100"
                                IsEnabled="False"
                                Background="#333"/>
                        <TextBlock Text="Level 4"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="200"
                                Height="100"
                                IsEnabled="False"
                                Background="#333"/>
                        <TextBlock Text="Level 5"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="200"
                                Height="100"
                                IsEnabled="False"
                                Background="#333"/>
                        <TextBlock Text="Level 6"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>
                    </StackPanel>

                </UniformGrid>

                <StackPanel HorizontalAlignment="Center" Margin="0,30,0,30">
                    <Button Width="300"
                            Height="80"
                            Background="#AA3333"
                            Click="TestMap_Click">
                        <TextBlock Text="TEST MAP"
                                   FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <TextBlock Text="Fejlesztői tesztpálya"
                               Foreground="LightGray"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Button Content="Vissza"
                Width="150"
                Height="40"
                HorizontalAlignment="Center"
                Margin="0,15"
                Grid.Row="2"
                Click="Back_Click"/>
    </Grid>
</Window>
