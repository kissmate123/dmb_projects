<Window x:Class="SimplePlatformer.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Platformer"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#222">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="300">

            <TextBlock Text="SIMPLE PLATFORMER"
                       FontSize="25"
                       FontWeight="Bold"
                       Foreground="White"
                       Width="258" Height="32"/>

            <Button Content="Játék indítása"
                    Height="50"
                    FontSize="18"
                    Click="StartGame_Click"
                    Margin="0,0,0,20"/>

            <Button Content="Kilépés"
                    Height="50"
                    FontSize="18"
                    Click="Exit_Click"/>
        </StackPanel>
    </Grid>
</Window>
